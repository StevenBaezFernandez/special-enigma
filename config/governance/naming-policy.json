{
  "rules": [
    {
      "pathRegex": "^apps/service/",
      "allowedPrefixes": ["api-", "service-"]
    },
    {
      "pathRegex": "^apps/client/web/",
      "allowedPrefixes": ["web-"]
    },
    {
      "pathRegex": "^apps/client/mobile/",
      "allowedPrefixes": ["mobile-"]
    },
    {
      "pathRegex": "^apps/client/desktop/",
      "allowedPrefixes": ["desktop-"]
    },
    {
      "pathRegex": "^apps/worker/",
      "allowedPrefixes": ["worker-"]
    },
    {
      "pathRegex": "^apps/edge/",
      "allowedPrefixes": ["bff-", "edge-"]
    },
    {
      "pathRegex": "^libs/domain/",
      "allowedPrefixes": ["domain-", "application-", "api-", "infra-"]
    }
  ],
  "exceptions": {}
}
