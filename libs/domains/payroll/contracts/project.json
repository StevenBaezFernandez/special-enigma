{
  "name": "contracts-payroll-contracts",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/payroll/contracts/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "type:contract",
    "scope:payroll"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domains/payroll/contracts",
        "main": "libs/domains/payroll/contracts/src/index.ts",
        "tsConfig": "libs/domains/payroll/contracts/tsconfig.lib.json",
        "assets": [
          "libs/domains/payroll/contracts/*.md"
        ],
        "rootDir": "."
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../../../coverage/libs/domains/payroll/contracts"
      }
    }
  }
}