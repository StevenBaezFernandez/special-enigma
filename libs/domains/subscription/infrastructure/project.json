{
  "name": "subscription-infrastructure",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/subscription/infrastructure/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": ["scope:subscription", "type:infrastructure"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/domains/subscription/infrastructure",
        "main": "libs/domains/subscription/infrastructure/src/index.ts",
        "tsConfig": "libs/domains/subscription/infrastructure/tsconfig.lib.json",
        "assets": ["libs/domains/subscription/infrastructure/*.md"],
        "rootDir": "libs/domains/subscription/infrastructure"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../../../coverage/libs/domains/subscription/infrastructure"
      }
    }
  }
}
