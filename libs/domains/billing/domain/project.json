{
  "name": "billing-domain",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/billing/domain/src",
  "projectType": "library",
  "tags": [
    "scope:billing",
    "type:domain",
    "platform:agnostic",
    "tenant-mode:schema",
    "criticality:high"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domains/billing/domain",
        "main": "libs/domains/billing/domain/src/index.ts",
        "tsConfig": "libs/domains/billing/domain/tsconfig.lib.json",
        "assets": [
          "libs/domains/billing/domain/*.md"
        ],
        "rootDir": "libs/domains/billing/domain"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/domains/billing/domain/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    }
  },
  "prefix": "virteex"
}
