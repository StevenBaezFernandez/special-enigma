{
  "name": "domain-projects-domain",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/projects/domain/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "type:domain",
    "scope:projects"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domains/projects/domain",
        "main": "libs/domains/projects/domain/src/index.ts",
        "tsConfig": "libs/domains/projects/domain/tsconfig.lib.json",
        "assets": [
          "libs/domains/projects/domain/*.md"
        ],
        "rootDir": "libs/domains/projects/domain/src"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../../../coverage/libs/domains/projects/domain"
      }
    }
  }
}