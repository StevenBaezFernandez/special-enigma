{
  "name": "application-purchasing-application",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/purchasing/application/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:purchasing",
    "type:application",
    "platform:agnostic",
    "criticality:high"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "rootDir": ".",
        "outputPath": "dist/libs/domains/purchasing/application",
        "main": "libs/domains/purchasing/application/src/index.ts",
        "tsConfig": "libs/domains/purchasing/application/tsconfig.lib.json",
        "assets": [
          "libs/domains/purchasing/application/*.md"
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "libs/domains/purchasing/application/**/*.ts"
        ]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../../../coverage/libs/domains/purchasing/application"
      }
    }
  }
}