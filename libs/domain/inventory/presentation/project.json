{
  "name": "domain-inventory-presentation",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/inventory/presentation/src",
  "projectType": "library",
  "tags": [
    "scope:inventory",
    "type:presentation",
    "platform:agnostic",
    "criticality:high"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/inventory/presentation",
        "main": "libs/domain/inventory/presentation/src/index.ts",
        "tsConfig": "libs/domain/inventory/presentation/tsconfig.lib.json",
        "assets": [
          "libs/domain/inventory/presentation/*.md"
        ],
        "rootDir": "libs/domains/inventory"
      }
    }
  },
  "prefix": "virteex"
}
