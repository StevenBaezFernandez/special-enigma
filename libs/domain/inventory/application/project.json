{
  "name": "domain-inventory-application",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/inventory/application/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:inventory",
    "type:application",
    "platform:agnostic",
    "criticality:high",
    "compliance:none",
    "tenant-mode:multi",
    "region:global"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/inventory/application",
        "main": "libs/domain/inventory/application/src/index.ts",
        "tsConfig": "libs/domain/inventory/application/tsconfig.lib.json",
        "assets": [
          "libs/domain/inventory/application/*.md"
        ],
        "generateExportsField": true
      }
    }
  }
}