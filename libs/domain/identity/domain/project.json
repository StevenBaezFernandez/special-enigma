{
  "name": "domain-identity-domain",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/identity/domain/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:identity",
    "type:domain",
    "platform:agnostic",
    "criticality:high",
    "tenant-mode:schema"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/identity/domain",
        "main": "libs/domain/identity/domain/src/index.ts",
        "tsConfig": "libs/domain/identity/domain/tsconfig.lib.json",
        "assets": [
          "libs/domain/identity/domain/*.md"
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../../../coverage/libs/domain/identity/domain"
      }
    }
  }
}
