{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../../../..",
    "outDir": "../../../../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "module": "commonjs"
  },
  "include": [
    "src/**/*.ts",
    "../../../../libs/platform/cache/src/**/*.ts"
  ],
  "exclude": [
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "../../../../libs/platform/cache/src/**/*.spec.ts",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ]
}
