{
  "name": "domain-accounting-presentation",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/accounting/presentation/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:accounting",
    "type:presentation",
    "platform:nest",
    "criticality:high",
    "tenant-mode:schema",
    "compliance:fiscal",
    "region:global"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/accounting/presentation",
        "main": "libs/domain/accounting/presentation/src/index.ts",
        "tsConfig": "libs/domain/accounting/presentation/tsconfig.lib.json",
        "assets": [
          "libs/domain/accounting/presentation/*.md"
        ],
        "generateExportsField": true
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "config": "libs/domain/accounting/presentation/vitest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}