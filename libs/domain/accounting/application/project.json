{
  "name": "domain-accounting-application",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/accounting/application/src",
  "projectType": "library",
  "tags": [
    "scope:accounting",
    "type:application",
    "platform:agnostic",
    "criticality:high",
    "tenant-mode:schema"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/accounting/application",
        "main": "libs/domain/accounting/application/src/index.ts",
        "tsConfig": "libs/domain/accounting/application/tsconfig.lib.json",
        "assets": [
          "libs/domain/accounting/application/*.md"
        ]
      }
    }
  },
  "prefix": "virteex"
}
