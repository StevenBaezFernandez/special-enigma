{
  "name": "domain-accounting-contracts",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/accounting/contracts/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:accounting",
    "type:contracts",
    "platform:agnostic",
    "criticality:high",
    "tenant-mode:schema",
    "compliance:none",
    "region:global"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/accounting/contracts",
        "main": "libs/domain/accounting/contracts/src/index.ts",
        "tsConfig": "libs/domain/accounting/contracts/tsconfig.lib.json",
        "assets": [
          "libs/domain/accounting/contracts/*.md"
        ],
        "generateExportsField": true
      }
    }
  }
}