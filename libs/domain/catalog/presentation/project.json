{
  "name": "domain-catalog-presentation",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/catalog/presentation/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:catalog",
    "type:presentation",
    "platform:nest",
    "criticality:high",
    "tenant-mode:schema",
    "compliance:none",
    "region:global"
  ],
  "// targets": "to see all targets run: nx show project domain-catalog-presentation --web",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/catalog/presentation",
        "main": "libs/domain/catalog/presentation/src/index.ts",
        "tsConfig": "libs/domain/catalog/presentation/tsconfig.lib.json",
        "assets": [
          "libs/domain/catalog/presentation/*.md"
        ],
        "generateExportsField": true
      }
    }
  }
}