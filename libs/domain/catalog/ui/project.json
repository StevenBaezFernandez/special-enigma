{
  "name": "domain-catalog-ui",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/catalog/ui/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [
    "scope:catalog",
    "type:ui",
    "profile:service-domain",
    "platform:web",
    "criticality:high",
    "compliance:none",
    "tenant-mode:multi",
    "region:global"
  ],
  "targets": {
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../../../coverage/libs/domain/catalog/ui"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/catalog/ui",
        "main": "libs/domain/catalog/ui/src/index.ts",
        "tsConfig": "libs/domain/catalog/ui/tsconfig.lib.json",
        "assets": [
          "libs/domain/catalog/ui/*.md"
        ],
        "generateExportsField": true
      }
    }
  }
}