{
  "name": "domain-admin-presentation",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/admin/presentation/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:admin",
    "type:presentation",
    "platform:agnostic",
    "criticality:medium"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/admin/presentation",
        "main": "libs/domain/admin/presentation/src/index.ts",
        "tsConfig": "libs/domain/admin/presentation/tsconfig.lib.json",
        "assets": [
          "libs/domain/admin/presentation/*.md"
        ],
        "generateExportsField": true
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../../../coverage/libs/domain/admin/presentation"
      }
    }
  }
}