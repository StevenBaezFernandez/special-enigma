{
  "name": "domain-purchasing-presentation",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/purchasing/presentation/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:purchasing",
    "type:presentation",
    "platform:agnostic",
    "criticality:high",
    "compliance:none",
    "tenant-mode:multi",
    "region:global"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/purchasing/presentation",
        "main": "libs/domain/purchasing/presentation/src/index.ts",
        "tsConfig": "libs/domain/purchasing/presentation/tsconfig.lib.json",
        "assets": [
          "libs/domain/purchasing/presentation/*.md"
        ],
        "generateExportsField": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "libs/domain/purchasing/presentation/**/*.ts"
        ]
      }
    }
  }
}