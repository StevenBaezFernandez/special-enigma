{
  "name": "domain-purchasing-ui",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/purchasing/ui/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:purchasing",
    "type:ui",
    "platform:agnostic",
    "criticality:medium"
  ],
  "targets": {
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../../../coverage/libs/domain/purchasing/ui"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/purchasing/ui",
        "main": "libs/domain/purchasing/ui/src/index.ts",
        "tsConfig": "libs/domain/purchasing/ui/tsconfig.lib.json",
        "assets": [
          "libs/domain/purchasing/ui/*.md"
        ],
        "generateExportsField": true
      }
    }
  }
}