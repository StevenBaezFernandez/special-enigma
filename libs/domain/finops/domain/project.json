{
  "name": "domain-finops-domain",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domain/finops/domain/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:finops",
    "type:domain",
    "platform:agnostic",
    "criticality:medium"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domain/finops/domain",
        "main": "libs/domain/finops/domain/src/index.ts",
        "tsConfig": "libs/domain/finops/domain/tsconfig.lib.json",
        "assets": [
          "libs/domain/finops/domain/*.md"
        ],
        "generateExportsField": true
      }
    }
  }
}