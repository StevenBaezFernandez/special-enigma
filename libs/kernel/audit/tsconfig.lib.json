{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../../dist/libs/kernel/audit",
    "tsBuildInfoFile": "../../../dist/libs/kernel/audit/.tsbuildinfo",
    "declaration": true,
    "composite": true,
    "rootDir": "src",
    "types": [
      "node"
    ],
    "target": "es2021",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true
  },
  "references": [
    { "path": "../telemetry-interfaces/tsconfig.lib.json" },
    { "path": "../tenant-context/tsconfig.lib.json" },
    { "path": "../../platform/audit/tsconfig.lib.json" }
  ],
  "include": [
    "src/**/*.ts"
  ]
}