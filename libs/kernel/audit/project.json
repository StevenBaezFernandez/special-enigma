{
  "name": "kernel-audit",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/kernel/audit/src",
  "projectType": "library",
  "tags": [
    "scope:kernel",
    "type:kernel",
    "platform:agnostic",
    "criticality:high",
    "compliance:none",
    "tenant-mode:multi",
    "region:global"
  ],
  "// targets": "to see all targets run: nx show project kernel-audit --web",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/kernel/audit",
        "main": "libs/kernel/audit/src/index.ts",
        "tsConfig": "libs/kernel/audit/tsconfig.lib.json",
        "assets": [
          "libs/kernel/audit/*.md"
        ],
        "generateExportsField": true
      }
    }
  }
}