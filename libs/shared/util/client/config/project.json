{
  "name": "shared-util-client-config",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/util/client/config/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:shared",
    "type:util",
    "platform:agnostic",
    "criticality:medium"
  ],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../../../../coverage/libs/shared/util/client/config"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/shared/util/client/config",
        "main": "libs/shared/util/client/config/src/index.ts",
        "tsConfig": "libs/shared/util/client/config/tsconfig.lib.json",
        "assets": [
          "libs/shared/util/client/config/*.md"
        ],
        "generateExportsField": true
      }
    }
  }
}