{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "../../../dist/libs/shared/ui",
    "declaration": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler", "module": "esnext"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
