{
  "name": "platform-storage",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/platform/storage/src",
  "prefix": "virteex",
  "projectType": "library",
  "tags": [
    "type:infrastructure",
    "platform:agnostic",
    "criticality:medium",
    "scope:platform"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/platform/storage",
        "main": "libs/platform/storage/src/index.ts",
        "tsConfig": "libs/platform/storage/tsconfig.lib.json",
        "assets": [
          "libs/platform/storage/*.md"
        ],
        "generateExportsField": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}