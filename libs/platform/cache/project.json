{
  "name": "platform-cache",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/platform/cache/src",
  "projectType": "library",
  "tags": [
    "type:infrastructure",
    "platform:agnostic",
    "criticality:medium",
    "scope:platform"
  ],
  "targets": {
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../../../coverage/libs/platform/cache"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/platform/cache",
        "main": "libs/platform/cache/src/index.ts",
        "tsConfig": "libs/platform/cache/tsconfig.lib.json",
        "assets": [
          "libs/platform/cache/*.md"
        ],
        "generateExportsField": true
      }
    }
  }
}