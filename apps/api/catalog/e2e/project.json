{
  "name": "api-catalog-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:catalog", "type:e2e", "platform:e2e", "criticality:low"],
  "implicitDependencies": ["api-catalog-app"],
  "targets": {
    "e2e": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/api/catalog/e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["api-catalog-app:build", "api-catalog-app:serve"]
    }
  }
}
