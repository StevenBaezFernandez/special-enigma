{
  "name": "api-gateway-legacy-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:gateway", "type:e2e", "platform:e2e", "criticality:low"],
  "implicitDependencies": ["api-gateway-legacy-app"],
  "targets": {
    "e2e": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/api-gateway-legacy-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": [
        "api-gateway-legacy-app:build",
        "api-gateway-legacy-app:serve"
      ]
    }
  }
}
