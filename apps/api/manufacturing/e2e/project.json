{
  "name": "api-manufacturing-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": [
    "api-manufacturing-app"
  ],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{e2eProjectRoot}"
      ],
      "options": {
        "jestConfig": "apps/api/manufacturing/e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": [
        "api-manufacturing-app:build",
        "api-manufacturing-app:serve"
      ]
    }
  },
  "tags": [
    "scope:manufacturing",
    "type:e2e",
    "platform:e2e",
    "criticality:low"
  ]
}
