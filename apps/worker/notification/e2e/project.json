{
  "name": "worker-notification-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:shared", "type:e2e", "platform:e2e", "criticality:low"],
  "implicitDependencies": ["worker-notification-app"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/worker-notification-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": [
        "worker-notification-app:build",
        "worker-notification-app:serve"
      ]
    }
  }
}
