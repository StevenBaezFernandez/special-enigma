{
  "name": "worker-scheduler-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:shared", "type:e2e", "platform:e2e", "criticality:low"],
  "implicitDependencies": ["worker-scheduler-app"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/worker-scheduler-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["worker-scheduler-app:build", "worker-scheduler-app:serve"]
    }
  }
}
