{
  "name": "virteex-auth-server-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["virteex-auth-server"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/virteex-auth-server-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["virteex-auth-server:build", "virteex-auth-server:serve"]
    }
  }
}
