{
  "name": "virteex-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "virteex",
  "sourceRoot": "apps/frontend/virteex-web/src",
  "tags": ["platform:web"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/frontend/virteex-web",
        "browser": "apps/frontend/virteex-web/src/main.ts",
        "tsConfig": "apps/frontend/virteex-web/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/frontend/virteex-web/public"
          }
        ],
        "styles": ["apps/frontend/virteex-web/src/styles.scss"],
        "stylePreprocessorOptions": {
          "includePaths": ["libs/shared/ui/src/lib/styles"]
        }
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/frontend/virteex-web/src/environments/environment.ts",
              "with": "apps/frontend/virteex-web/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "10kb",
              "maximumError": "20kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "virteex-web:build:production"
        },
        "development": {
          "buildTarget": "virteex-web:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "apps/frontend/virteex-web/proxy.conf.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "virteex-web:build",
        "port": 4200,
        "staticFilePath": "dist/apps/frontend/virteex-web/browser",
        "spa": true
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../coverage/apps/frontend/virteex-web"
      }
    }
  }
}
