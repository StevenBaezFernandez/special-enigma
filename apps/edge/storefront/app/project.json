{
  "name": "edge-storefront-app",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/edge/storefront/app/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/edge/storefront/app",
        "main": "apps/edge/storefront/app/src/main.ts",
        "tsConfig": "apps/edge/storefront/app/tsconfig.app.json",
        "compiler": "tsc",
        "target": "node",
        "webpackConfig": "apps/edge/storefront/app/webpack.config.js"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        },
        "development": {}
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "edge-storefront-app:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "edge-storefront-app:build:development"
        },
        "production": {
          "buildTarget": "edge-storefront-app:build:production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/edge/storefront/app/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": [
    "scope:edge",
    "scope:store",
    "type:bff",
    "platform:node",
    "criticality:medium"
  ]
}
