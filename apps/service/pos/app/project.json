      "options": {
        "outputPath": "dist/apps/service/pos",
        "main": "apps/service/pos/app/src/main.ts",
        "tsConfig": "apps/service/pos/app/tsconfig.app.json",
        "compiler": "tsc",
        "target": "node",
        "webpackConfig": "apps/service/pos/app/webpack.config.js"
      }
    }
  }
}
