{
  "name": "service-pos",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/service/pos/app/src",
  "projectType": "application",
  "tags": [
    "scope:pos",
    "type:api",
    "platform:node",
    "criticality:medium"
