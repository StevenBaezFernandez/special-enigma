{
  "name": "service-accounting-app",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/service/accounting/app/src",
  "projectType": "application",
  "tags": [
    "scope:accounting",
    "type:app",
    "platform:agnostic",
    "criticality:medium"
  ],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/apps/service-accounting-app",
        "main": "apps/service/accounting/app/src/main.ts",
        "tsConfig": "apps/service/accounting/app/tsconfig.app.json",
        "assets": [
          "apps/service/accounting/app/src/assets"
        ],
        "webpackConfig": "apps/service/accounting/app/webpack.config.js"
      },
      "configurations": {
        "development": {},
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": [
        "build"
      ],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/service-accounting-app/package.json",
        "{workspaceRoot}/dist/apps/service-accounting-app/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": [
        "build"
      ],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/apps/service-accounting-app/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": [
        "prune-lockfile",
        "copy-workspace-modules"
      ],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "dependsOn": [
        "build"
      ],
      "options": {
        "command": "node dist/apps/service-accounting-app/main.js"
      },
      "configurations": {
        "development": {
          "command": "node dist/apps/service-accounting-app/main.js"
        },
        "production": {
          "command": "NODE_ENV=production ACCOUNTING_DB_CONNECT=true ACCOUNTING_KAFKA_ENABLED=true node dist/apps/service-accounting-app/main.js"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "jestConfig": "apps/service/accounting/app/jest.config.cts",
        "passWithNoTests": true
      }
    }
  }
}
