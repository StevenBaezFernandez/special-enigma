{
  "name": "web-site-app",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "virteex",
  "sourceRoot": "apps/client/web/site/app/src",
  "tags": [
    "scope:web-site",
    "type:app",
    "platform:web",
    "criticality:medium"
  ],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/client/web/site/app",
        "browser": "apps/client/web/site/app/src/main.ts",
        "tsConfig": "apps/client/web/site/app/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/client/web/site/app/public"
          }
        ],
        "styles": [
          "apps/client/web/site/app/src/styles.scss"
        ],
        "server": "apps/client/web/site/app/src/main.server.ts",
        "ssr": {
          "entry": "apps/client/web/site/app/src/server.ts"
        },
        "outputMode": "server"
      },
      "configurations": {
        "production": { "fileReplacements": [ { "replace": "apps/client/web/site/app/src/environments/environment.ts", "with": "apps/client/web/site/app/src/environments/environment.prod.ts" } ] },
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": { "proxyConfig": "apps/client/web/site/app/proxy.conf.json" },
      "configurations": {
        "production": { "fileReplacements": [ { "replace": "apps/client/web/site/app/src/environments/environment.ts", "with": "apps/client/web/site/app/src/environments/environment.prod.ts" } ] },
        "production": {
          "buildTarget": "web-site-app:build:production"
        },
        "development": {
          "buildTarget": "web-site-app:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "port": 4206
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "web-site-app:build",
        "port": 4206,
        "staticFilePath": "dist/apps/client/web/site/app/browser",
        "spa": true
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../coverage/apps/client/web/site/app"
      }
    }
  }
}
