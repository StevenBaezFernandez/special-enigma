  "name": "@virteex/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps",
    "nx": "nx",
    "arch:check": "node tools/validate-architecture-boundaries.mjs",
    "arch:validate-tags": "node tools/validate-project-tags.mjs",
    "arch:validate-naming": "node tools/quality-gates/validate-naming.mjs",
    "quality:lint": "nx run-many --target=lint --all",
    "quality:format": "prettier --write .",
    "quality:check-format": "prettier --check .",
    "quality:dep-graph": "depcruise --validate .dependency-cruiser.js libs apps",
    "quality:docs": "node tools/quality-gates/validate-docs-consistency.mjs",
    "quality:e2e-coverage": "node tools/quality-gates/validate-e2e-coverage.mjs",
    "test:unit": "nx run-many --target=test --all",
    "test:e2e": "nx run-many --target=e2e --all",
    "test:validate-backend": "node tools/validate-backend-test-targets.mjs",
    "security:sbom": "cyclonedx-npm --output-file sbom.json",
    "security:sign": "cosign sign-blob --yes --key cosign.key --output-signature sbom.json.sig sbom.json",
    "security:verify": "cosign verify-blob --key cosign.key --signature sbom.json.sig sbom.json",
    "security:policies": "./tools/validate-policies.sh",
    "readiness:check": "./tools/enforce-production-readiness.sh",
    "readiness:commercial": "node tools/readiness/validate-commercial-readiness.mjs",
    "readiness:evidence": "node tools/readiness/generate-evidence-pack.mjs",
    "readiness:report": "node tools/readiness/generate-release-report.mjs",
    "governance:consistency": "node tools/quality-gates/validate-operational-consistency.mjs",
    "governance:scorecard": "node tools/quality-gates/report-governance-scorecard.mjs",
    "governance:check": "npm run governance:consistency && npm run arch:validate-tags && npm run arch:validate-naming && npm run test:validate-backend && npm run quality:e2e-coverage",
    "doctor": "npm run governance:check",
    "dev:frontend": "nx serve web-portal-app",
    "dev:backend": "nx serve api-gateway-app",
    "build:frontend": "nx build web-portal-app",
    "build:backend": "nx build api-gateway-app",
    "quality:plugin-isolation": "node tools/quality-gates/validate-plugin-isolation.mjs"
  },
