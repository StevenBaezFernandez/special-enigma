    {
      "type": "node",
      "request": "launch",
      "name": "Debug virteex-api-gateway with Nx",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "nx",
        "serve",
        "virteex-api-gateway"
      ],
      "env": {
        "NODE_OPTIONS": "--inspect=9229"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/apps/virteex-api-gateway/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    },
